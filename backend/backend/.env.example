# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# OAuth 2.0 Client ID de Google Cloud Console (tipo "Web application").
# El Client ID es público (también lo usa el frontend); el flujo de ID token
# NO necesita el Client Secret en ningún lado, por eso no aparece aquí.
GOOGLE_CLIENT_ID= 848173015154-ujn128pl6nb8bdfum019lsc58p2sdilo.apps.googleusercontent.com

# Secreto para firmar los JWT propios de la app (genera uno largo y aleatorio,
# p. ej.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=

# Expiración del JWT (formato ms/zeit: 1h, 7d, etc.)
JWT_EXPIRES_IN=1h
